{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/core/**/*",
    "src/storage/**/*",
    "src/guards/**/*",
    "src/index.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "external",
    "src/app/**/*",
    "src/lib/**/*",
    "**/*.test.ts"
  ]
}
